# Copy this file to .env (and optionally .env.local for local overrides).
# Variables prefixed with EXPO_PUBLIC_ are embedded in the JS bundle.
# Never put secrets in EXPO_PUBLIC_ variables.

# ── API ───────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000
# If Nest uses a global prefix (e.g. app.setGlobalPrefix('api')):
# EXPO_PUBLIC_API_PREFIX=api
# Android emulator → API on your computer: http://10.0.2.2:3000
# Physical device → same Wi‑Fi LAN IP as your machine, e.g. http://192.168.1.42:3000

# ── App ───────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_NAME=WatchCue
EXPO_PUBLIC_APP_VERSION=1.0.0
