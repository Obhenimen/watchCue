# ── API ───────────────────────────────────────────────────────────────────────
# iOS simulator and Android emulator can reach localhost directly.
# For a physical device, override this in .env.local with your machine's LAN IP.
EXPO_PUBLIC_API_URL=http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_NAME=WatchCue
EXPO_PUBLIC_APP_VERSION=1.0.0
